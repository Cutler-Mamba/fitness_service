# Server
RUST_LOG=fitness_app=debug,tower_http=debug
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database
DATABASE_URL=sqlite:./data/fitness.db?mode=rwc
# DATABASE_URL=postgres://fitness:fitness@localhost:5432/fitness
DATABASE_MAX_CONNECTIONS=10

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT
JWT_SECRET=change-me-to-a-random-secret-in-production
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096

# Feishu (webhook mode)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_WEBHOOK_PATH=/api/v1/feishu/event

# WeChat Channel
# Set to "ilink" for iLink Bot long-polling (no public IP needed)
# Set to "webhook" for WeChat Open Platform webhook mode
WECHAT_CHANNEL=ilink

# --- iLink Bot (long-polling, no public IP needed) ---
WECHAT_ILINK_URL=https://ilinkai.weixin.qq.com
WECHAT_ACCOUNT_ID=
WECHAT_TOKEN=
WECHAT_CONTEXT_DIR=./data/weixin/context

# --- WeChat Webhook (requires public IP) ---
# WECHAT_CHANNEL=webhook
# WECHAT_BOT_TOKEN=
# WECHAT_VERIFICATION_TOKEN=
# WECHAT_ENCRYPT_KEY=
# WECHAT_WEBHOOK_PATH=/api/v1/wechat/event
